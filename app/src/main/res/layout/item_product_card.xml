<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="166dp"
    android:layout_height="250dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="#E8F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgProduct"
            android:layout_width="match_parent"
            android:layout_height="138dp"
            android:contentDescription="Product"
            android:scaleType="centerCrop"
            tools:src="@mipmap/traxanhbidao" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trà xanh bí đao"
            android:textSize="11sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="8dp" />

        <!-- Rating Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:baselineAligned="false">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/btn_star_big_on"
                android:contentDescription="Star" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.9"
                android:textSize="9sp"
                android:textColor="#FFA000"
                android:paddingStart="2dp" />

            <TextView
                android:id="@+id/tvReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  1k  Đánh giá"
                android:textSize="9sp"
                android:textColor="#AAAAAA" />

        </LinearLayout>

        <!-- Size & Price Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="9dp">

            <!-- M Size -->
            <TextView
                android:id="@+id/tvSizeM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_size_tag"
                android:text="M"
                android:textSize="10sp"
                android:textColor="#E53935"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp" />

            <TextView
                android:id="@+id/tvPriceM"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="16.000"
                android:textSize="9sp"
                android:textColor="#222222"
                android:paddingStart="4dp" />

            <!-- L Size -->
            <TextView
                android:id="@+id/tvSizeL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_size_tag"
                android:text="L"
                android:textSize="10sp"
                android:textColor="#E53935"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp" />

            <TextView
                android:id="@+id/tvPriceL"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="19.000"
                android:textSize="9sp"
                android:textColor="#222222"
                android:paddingStart="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/tvVipM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vip_tag"
                android:paddingStart="4dp"
                android:paddingTop="1dp"
                android:paddingEnd="4dp"
                android:paddingBottom="1dp"
                android:text="@string/home_vip_badge"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVipPriceM"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:text="16.000"
                android:textColor="#222222"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvVipL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vip_tag"
                android:paddingStart="4dp"
                android:paddingTop="1dp"
                android:paddingEnd="4dp"
                android:paddingBottom="1dp"
                android:text="@string/home_vip_badge"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVipPriceL"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:text="19.000"
                android:textColor="#222222"
                android:textSize="9sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
