<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/screen_background"
    tools:context="com.teatrack_mcd_253eie502802_group02.shared.ui.NavBarClient">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/nav_bar_client"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="@dimen/nav_bar_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.TopRounded">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/nav_home"
                style="@style/NavBarItem"
                android:layout_width="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/nav_home_icon"
                    style="@style/NavBarIcon"
                    android:contentDescription="@string/nav_home"
                    android:src="@drawable/home" />

                <TextView
                    android:id="@+id/nav_home_label"
                    style="@style/NavBarLabel"
                    android:text="@string/nav_home" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_menu"
                style="@style/NavBarItem"
                android:layout_width="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/nav_menu_icon"
                    style="@style/NavBarIcon"
                    android:contentDescription="@string/nav_menu"
                    android:src="@drawable/burger" />

                <TextView
                    android:id="@+id/nav_products_label"
                    style="@style/NavBarLabel"
                    android:text="@string/nav_menu" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_orders"
                style="@style/NavBarItem"
                android:layout_width="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/nav_orders_icon"
                    style="@style/NavBarIcon"
                    android:contentDescription="@string/nav_orders"
                    android:src="@drawable/bag1" />

                <TextView
                    android:id="@+id/nav_orders_label"
                    style="@style/NavBarLabel"
                    android:text="@string/nav_orders" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/nav_promotion"
                style="@style/NavBarItem"
                android:layout_width="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/nav_promotion_icon"
                    style="@style/NavBarIcon"
                    android:contentDescription="@string/nav_promotion"
                    android:src="@drawable/coupon1" />

                <TextView
                    android:id="@+id/nav_promotion_label"
                    style="@style/NavBarLabel"
                    android:text="@string/nav_promotion" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_profile"
                style="@style/NavBarItem"
                android:layout_width="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/nav_profile_icon"
                    style="@style/NavBarIcon"
                    android:contentDescription="@string/nav_profile"
                    android:src="@drawable/user" />

                <TextView
                    android:id="@+id/nav_profile_label"
                    style="@style/NavBarLabel"
                    android:text="@string/nav_profile" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
