<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context="com.teatrack_mcd_253eie502802_group02.shared.ui.NavBarAdmin">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/nav_bar_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="@dimen/nav_bar_elevation"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.TopRounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/nav_dashboard"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_dashboard_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_dashboard"
                        android:src="@drawable/chart" />

                    <TextView
                        android:id="@+id/nav_dashboard_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_dashboard" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_products"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_products_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_products"
                        android:src="@drawable/bag1" />

                    <TextView
                        android:id="@+id/nav_products_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_products" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_orders"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_orders_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_orders"
                        android:src="@drawable/cart" />

                    <TextView
                        android:id="@+id/nav_orders_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_orders" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_account"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_account_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_account"
                        android:src="@drawable/users" />

                    <TextView
                        android:id="@+id/nav_account_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_account" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_forum"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_forum_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_forum"
                        android:src="@drawable/documentadd" />

                    <TextView
                        android:id="@+id/nav_forum_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_forum" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_branch"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_branch_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_branch"
                        android:src="@drawable/location" />

                    <TextView
                        android:id="@+id/nav_branch_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_branch" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_feedbacks"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_feedbacks_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_feedbacks"
                        android:src="@drawable/call" />

                    <TextView
                        android:id="@+id/nav_feedbacks_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_feedbacks" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_promotion"
                    style="@style/NavBarItem"
                    android:layout_width="100dp">

                    <ImageView
                        android:id="@+id/nav_promotion_icon"
                        style="@style/NavBarIcon"
                        android:contentDescription="@string/nav_promotion"
                        android:src="@drawable/coupon3" />

                    <TextView
                        android:id="@+id/nav_promotion_label"
                        style="@style/NavBarLabel"
                        android:text="@string/nav_promotion" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>