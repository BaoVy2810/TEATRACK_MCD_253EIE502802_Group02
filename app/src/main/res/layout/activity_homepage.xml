<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context="com.teatrack_mcd_253eie502802_group02.client.Homepage">

    <include
        android:id="@+id/headerClient"
        layout="@layout/activity_header_client"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/navBarClient"
        layout="@layout/activity_nav_bar_client"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/navBarClient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerClient">

        <LinearLayout
            android:id="@+id/homeContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="18dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/home_search"
                        android:src="@drawable/search"
                        app:tint="@color/brand_blue" />

                    <EditText
                        android:id="@+id/edtSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/str_search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"
                        android:textColor="@color/nav_inactive"
                        android:textColorHint="@color/brand_blue"
                        android:textSize="10sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutBanners"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        layout="@layout/item_banner"
                        android:layout_width="360dp"
                        android:layout_height="142dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_banner"
                        android:layout_width="360dp"
                        android:layout_height="142dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_banner"
                        android:layout_width="360dp"
                        android:layout_height="142dp"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutDots"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:gravity="center"
                android:orientation="horizontal" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="28dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        style="@style/HomeSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/home_our_beverages" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutBeverageCategories"
                            android:layout_width="400dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <include
                                layout="@layout/item_beverage_category"
                                android:visibility="gone"
                                tools:visibility="visible" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/tvCategoryDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.25"
                        android:paddingStart="32dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="32dp"
                        android:text="@string/home_beverage_description"
                        android:textColor="@color/black"
                        android:textSize="8sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/HomeSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="14dp"
                android:text="@string/home_featured_products" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="18dp"
                android:paddingEnd="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutFeaturedProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        layout="@layout/item_product_card"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_product_card"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_product_card"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="#E8F6FF"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="28dp">

                <TextView
                    style="@style/HomeSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp"
                    android:text="@string/home_exciting_promotions" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingStart="18dp"
                    android:paddingEnd="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutPromotions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include
                            layout="@layout/item_promotion_banner"
                            android:visibility="gone"
                            tools:visibility="visible" />

                        <include
                            layout="@layout/item_promotion_banner"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                style="@style/HomeSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingStart="18dp"
                android:paddingEnd="14dp"
                android:text="@string/home_whats_new" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="18dp"
                android:paddingEnd="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutNews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        layout="@layout/item_news_card"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_news_card"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <include
                        layout="@layout/item_news_card"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
